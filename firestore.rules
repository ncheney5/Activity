rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    match /users/{userId} {
      // User can read own doc; admin can read any user doc
      allow read: if isOwner(userId) || isAdmin();

      // User can create only their own doc and cannot create self as admin
      // Admin can create any user doc
      allow create: if (isOwner(userId) && request.resource.data.role != "admin")
                    || isAdmin();

      // User can update own doc, but role must stay the same
      // Admin can update any user doc
      allow update: if (isOwner(userId)
                        && request.resource.data.role == resource.data.role)
                    || isAdmin();

      // Only admins can delete user docs
      allow delete: if isAdmin();
    }

    match /activities/{activityId} {
      // Any authenticated user can read
      allow read: if isSignedIn();

      // Only admins can write
      allow create, update, delete: if isAdmin();
    }

    match /rsvps/{rsvpId} {
      // Any authenticated user can read all RSVPs
      allow read: if isSignedIn();

      // User can create only their own RSVP
      allow create: if isSignedIn()
                    && request.resource.data.ownerUid == request.auth.uid;

      // User can update only their own RSVP, and cannot transfer ownership
      allow update: if isSignedIn()
                    && resource.data.ownerUid == request.auth.uid
                    && request.resource.data.ownerUid == resource.data.ownerUid;

      // User can delete only their own RSVP
      allow delete: if isSignedIn()
                    && resource.data.ownerUid == request.auth.uid;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}